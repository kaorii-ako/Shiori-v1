# ============================================================================
# Shiori environment — copy this file to `.env` and fill in the REQUIRED values.
# Only the first two variables are needed for real accounts + Google Classroom.
# (Vite reads VITE_* vars; they are bundled into the client at build time.)
# ============================================================================

# ── REQUIRED · Supabase (auth + cloud data) ─────────────────────────────────
# Create a free project at https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Sign-In and Google Classroom are configured INSIDE Supabase, not here:
#   Supabase dashboard → Authentication → Providers → Google
#   (paste your Google OAuth Client ID + Secret there).
# See SETUP.md for the full, step-by-step guide.

# ── OPTIONAL · Gemini AI key (or set it later in the app: Settings → API Keys)─
# Free key: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# ── OPTIONAL · Public app URL (used for share links / PDFs) ─────────────────
# Defaults to the current origin in the browser; set for production if needed.
VITE_APP_URL=http://localhost:5173

# ============================================================================
# Everything below is OPTIONAL and only matters if you self-host the Express
# server or enable paid plans. The core app (Vercel + Supabase) does NOT need it.
# ============================================================================

# ── Self-hosted Express server (npm run dev:server) ─────────────────────────
# PORT must match the vite proxy target in client/vite.config.js (3000).
# PORT=3000
# SESSION_SECRET=any-random-32-char-string
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Stripe (only if you enable the Pro tier) ────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# VITE_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_ID_PRO_MONTHLY=
# STRIPE_PRICE_ID_PRO_ANNUAL=
