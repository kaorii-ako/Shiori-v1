# ============================================================
# Shiori — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# ─── APPWRITE AUTH (required for real accounts) ─────────────
# 1. Create free project at https://cloud.appwrite.io
# 2. Copy Project ID and endpoint from Settings
# 3. Enable Email/Password auth: Auth → Settings → Email/Password ON
# 4. Enable GitHub OAuth: Auth → Settings → OAuth2 → GitHub
#    → Create GitHub OAuth App at https://github.com/settings/developers
#    → Copy Client ID + Secret into Appwrite
#    → Redirect URI from Appwrite → paste into GitHub app
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_appwrite_project_id_here

# ─── GOOGLE OAUTH (for Classroom/Gmail/Calendar sync) ────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── GEMINI AI (optional — user can also set key in app Settings) ─
# Get from: https://aistudio.google.com/apikey (free)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── STRIPE PAYMENTS (optional — enables Pro plan) ───────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_MONTHLY=price_monthly_id_here
STRIPE_PRICE_ANNUAL=price_annual_id_here

# Session secret (any 32+ char random string)
SESSION_SECRET=change_this_to_a_random_string
