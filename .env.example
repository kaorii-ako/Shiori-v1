# ============================================================
# Shiori — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Google OAuth 2.0
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google Gemini AI (optional — enables real AI study plans)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Appwrite (optional — enables cloud sync)
# Get from: https://cloud.appwrite.io/console
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id_here
APPWRITE_DATABASE_ID=your_database_id_here
APPWRITE_COLLECTION_ASSIGNMENTS=assignments
APPWRITE_COLLECTION_COURSES=courses

# Stripe (optional — enables Shiori Pro payments)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Create prices at: https://dashboard.stripe.com/products
STRIPE_PRICE_MONTHLY=price_monthly_id_here
STRIPE_PRICE_ANNUAL=price_annual_id_here

# Session
SESSION_SECRET=change_this_to_a_random_string
